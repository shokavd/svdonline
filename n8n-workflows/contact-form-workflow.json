        "emailFormat": "html",
        "message": "=<div style=\"font-family: sans-serif; max-width: 600px; color: #1a0508;\">\n  <div style=\"background: #FF2D8A; padding: 24px 32px; border-radius: 12px 12px 0 0;\">\n    <h2 style=\"color: #fff; margin: 0; font-size: 20px;\">{{ $json.body.locale === 'nl' ? 'Bericht ontvangen' : 'Message received' }}</h2>\n  </div>\n\n  <div style=\"background: #fff8f3; padding: 32px; border: 1px solid #f0d5c5; border-top: none; border-radius: 0 0 12px 12px;\">\n    {{ $json.body.locale === 'nl'\n      ? '<p style=\"margin: 0 0 16px; font-size: 15px;\">Hoi ' + $json.body.name.split(' ')[0] + ',</p><p style=\"font-size: 15px; line-height: 1.6; color: #3a2020;\">Bedankt voor je bericht. Ik heb het ontvangen en reageer binnen twee werkdagen.</p><p style=\"font-size: 15px; line-height: 1.6; color: #3a2020;\">Als je ondertussen wil kijken hoe we kunnen samenwerken, bekijk dan de <a href=\"https://svdonline.com/nl/work-with-me\" style=\"color: #FF2D8A;\">pakketten</a>.</p>'\n      : '<p style=\"margin: 0 0 16px; font-size: 15px;\">Hi ' + $json.body.name.split(' ')[0] + ',</p><p style=\"font-size: 15px; line-height: 1.6; color: #3a2020;\">Thanks for reaching out. I\\'ve received your message and will get back to you within two business days.</p><p style=\"font-size: 15px; line-height: 1.6; color: #3a2020;\">In the meantime, if you want to explore working together, take a look at the <a href=\"https://svdonline.com/en/work-with-me\" style=\"color: #FF2D8A;\">packages</a>.</p>'\n    }}\n\n    <p style=\"margin-top: 32px; font-size: 15px;\">{{ $json.body.locale === 'nl' ? 'Met vriendelijke groet,' : 'Best,' }}</p>\n    <p style=\"font-weight: 700; font-size: 15px; color: #FF2D8A; margin: 4px 0 0;\">Shoka</p>\n    <p style=\"font-size: 13px; color: #7a5048; margin: 4px 0 0;\">SVD Online · <a href=\"https://svdonline.com\" style=\"color: #7a5048;\">svdonline.com</a></p>\n  </div>\n</div>",
        "options": {}
      },
