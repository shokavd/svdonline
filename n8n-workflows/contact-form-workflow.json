        "emailFormat": "html",
        "message": "=<div style=\"font-family: sans-serif; max-width: 600px; color: #1a0508;\">\n  <div style=\"background: #FF2D8A; padding: 24px 32px; border-radius: 12px 12px 0 0;\">\n    <h2 style=\"color: #fff; margin: 0; font-size: 20px;\">New contact form submission</h2>\n    <p style=\"color: rgba(255,255,255,0.8); margin: 4px 0 0; font-size: 14px;\">SVD Online · {{ $json.body.locale === 'nl' ? 'Dutch visitor' : 'English visitor' }}</p>\n  </div>\n\n  <div style=\"background: #fff8f3; padding: 32px; border: 1px solid #f0d5c5; border-top: none; border-radius: 0 0 12px 12px;\">\n    <table style=\"width: 100%; border-collapse: collapse; font-size: 14px;\">\n      <tr>\n        <td style=\"padding: 10px 0; color: #7a5048; width: 110px; vertical-align: top;\">Name</td>\n        <td style=\"padding: 10px 0; font-weight: 600; color: #1a0508;\">{{ $json.body.name }}</td>\n      </tr>\n      <tr style=\"border-top: 1px solid #f0d5c5;\">\n        <td style=\"padding: 10px 0; color: #7a5048; vertical-align: top;\">Email</td>\n        <td style=\"padding: 10px 0; font-weight: 600;\"><a href=\"mailto:{{ $json.body.email }}\" style=\"color: #FF2D8A;\">{{ $json.body.email }}</a></td>\n      </tr>\n      <tr style=\"border-top: 1px solid #f0d5c5;\">\n        <td style=\"padding: 10px 0; color: #7a5048; vertical-align: top;\">Subject</td>\n        <td style=\"padding: 10px 0; font-weight: 600; color: #1a0508;\">{{ $json.body.subject }}</td>\n      </tr>\n      <tr style=\"border-top: 1px solid #f0d5c5;\">\n        <td style=\"padding: 10px 0; color: #7a5048; vertical-align: top;\">Message</td>\n        <td style=\"padding: 10px 0; color: #1a0508; white-space: pre-wrap;\">{{ $json.body.message }}</td>\n      </tr>\n    </table>\n\n    <div style=\"margin-top: 28px; padding-top: 20px; border-top: 1px solid #f0d5c5; display: flex; gap: 12px;\">\n      <a href=\"mailto:{{ $json.body.email }}?subject=Re: {{ $json.body.subject }}\"\n         style=\"display: inline-block; background: #FF2D8A; color: #fff; font-weight: 700; padding: 12px 24px; border-radius: 10px; text-decoration: none; font-size: 14px;\">\n        Reply to {{ $json.body.name }} →\n      </a>\n    </div>\n\n    <p style=\"margin-top: 24px; font-size: 11px; color: #a09090;\">Submitted via svdonline.com/contact · {{ new Date().toISOString() }}</p>\n  </div>\n</div>",
        "options": {}
      },
      "id": "email-to-shoka",
      "name": "Email to Shoka",
      "type": "n8n-nodes-base.emailSend",
